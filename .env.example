# SessionLens Configuration
# Copy this file to .env and fill in your values

# OpenAI API key (for token counting and optional embedding features)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic API key (optional, for Anthropic token counting)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Default model for session analysis
SESSION_ANALYSIS_MODEL=gpt-4o-mini

# Session data directory (default: ~/.session-lens/sessions)
SESSIONS_DIR=~/.session-lens/sessions

# Database path (default: ~/.session-lens/session-lens.db)
DB_PATH=~/.session-lens/session-lens.db
